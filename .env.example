# Database configuration
DATABASE_URL=postgresql://sentinel_admin:sentinel_password_change_me@localhost:5432/sentinelvault

# Redis configuration
REDIS_URL=redis://localhost:6379

# Service ports
AUTH_PORT=3001
SYNC_PORT=3002
SECURITY_ANALYSIS_PORT=3003

# Security keys (placeholders)
JWT_SECRET=super_secret_jwt_key_do_not_use_in_production
OPAQUE_SERVER_SETUP=placeholder_opaque_setup_key

# AI Insights — Gemini API key (required for LLM summaries; omit for static fallbacks)
GEMINI_API_KEY=your_gemini_api_key_here

# Have I Been Pwned API key (required for email breach monitoring)
HIBP_API_KEY=your_hibp_api_key_here

# AES-256-GCM key for encrypting email addresses stored in breach_opt_ins.
# Generate with: openssl rand -hex 32
# MUST be set in production — the default dev value in BreachStore is insecure.
BREACH_ENCRYPTION_KEY=change-this-to-a-64-hex-char-random-value-in-production

# VirusTotal API key (required for file hash reputation and full-scan)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
